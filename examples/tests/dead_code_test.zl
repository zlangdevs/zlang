fun pick(x: i32) >> i32 {
    if x > 0 {
        return 1;
        @printf("unreachable after return\n");
    } else {
        return 2;
    }
    return 3;
}

fun count_first_even(p: ptr<i32>, n: i32) >> i32 {
    for i32 i = 0; i < n; i++ {
        if p[i] % 2 == 0 {
            return i;
            i = i + 100;
        }
    }
    return -1;
}

fun main() >> i32 {
    @printf("(expected 1):%d\n", pick(5));
    @printf("(expected 2):%d\n", pick(-5));
    arr<i32, 4> a;
    a[0] = 1; a[1] = 3; a[2] = 4; a[3] = 6;
    ptr<i32> p = &a[0];
    @printf("(expected 2):%d\n", count_first_even(p, 4));
    return 0;
}
