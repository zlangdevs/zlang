use std.assert

fun main() >> i32 {
    test_start();

    assert_true(2 + 2 == 4, "basic arithmetic");
    test_pass("assert_true");

    assert_false(2 + 2 == 5, "false branch");
    test_pass("assert_false");

    assert_equal(42, 42, "equal ints");
    test_pass("assert_equal");

    assert_equal_float(3.14159, 3.14159, 0.000001, "equal floats");
    test_pass("assert_equal_float");

    i32 result = test_summary();
    @printf("(expected 0):%d\n", result);
    return result;
}
