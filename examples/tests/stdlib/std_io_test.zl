use std.io

fun main() >> i32 {
    i32 p = print("io_print");
    @printf("\n(expected 8):%d\n", p);

    i32 pl = println("io_line");
    @printf("(expected 8):%d\n", pl);

    i32 pi = printInt(42);
    @printf("\n(expected 2):%d\n", pi);

    i32 pf = printFloat(2.5);
    @printf("\n(expected 8):%d\n", pf);

    i32 ep = eprint("err");
    @printf("\n(expected 3):%d\n", ep);

    i32 epl = eprintln("errln");
    @printf("(expected 6):%d\n", epl);

    arr<u8, 4> tiny;
    i32 read_len = readLine(&tiny[0], 1);
    @printf("(expected 0):%d\n", read_len);
    @printf("(expected 0):%d\n", tiny[0]);

    return 0;
}
