fun main() >> i32 {
    f16 a = 1.0;
    f32 b = 3.14;
    f64 c = 2.718281828459045;
    f32 a_casted = a;
    f32 c_casted = c as _;
    @printf("f16 value(expected 1.000000):%f\n", a_casted);
    @printf("f32 value(expected 3.140000):%f\n", b);
    @printf("f64 value(expected 2.718282):%f\n", c);
    @printf("f32 value(expected 2.718282):%f\n", c_casted);

    f32 m1 = 1.0;
    f32 m2 = 0.88;
    f32 m3 = m1 * m2;
    f32 m4 = m1 / 1.136;
    f32 mixed = m3 + m4;
    i32 float_mul_div_ok = 0;
    if (mixed > (1.7 as f32) && mixed < (1.8 as f32)) {
        float_mul_div_ok = 1;
    }
    @printf("(expected 1):%d\n", float_mul_div_ok);

    return 0;
}
